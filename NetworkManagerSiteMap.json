        "func": "let view_config = {};\n// Check if we got a result and it's not empty\nif (msg.payload && msg.payload.length > 0 && msg.payload[0]) {\n    view_config = msg.payload[0];\n} else {\n    // Fallback to default if no view is saved\n    view_config = { scale: 1, translate_x: 0, translate_y: 0 };\n}\n\nmsg.payload = {\n    type: \"LOAD_DEFAULT_VIEW\",\n    view: {\n        scale: parseFloat(view_config.scale) || 1,\n        translateX: parseFloat(view_config.translate_x) || 0,\n        translateY: parseFloat(view_config.translate_y) || 0\n    }\n};\nreturn msg;",
