    {
        "id": "d791cf6f7321368b",
        "type": "function",
        "z": "04a5753d1cd88563",
        "name": "Format Alarm for Map",
        "func": "// --- Helper Functions (copy/paste these) ---\n\n// Calculates distance between {x, y} points\nfunction getDistance(p1, p2) {\n    const dx = p1.x - p2.x;\n    const dy = p1.y - p2.y;\n    return Math.sqrt(dx * dx + dy * dy);\n}\n\n// Main function to find (x, y) from a meter value\nfunction meterToCoords(meterValue, zoneData) {\n    if (!zoneData || !zoneData.path_points || zoneData.path_points.length < 2 || zoneData.path_points[0] === null) {\n        return null; // Not enough data to interpolate\n    }\n    \n    const path_points = zoneData.path_points;\n    const meter_start = zoneData.meter_start;\n    const meter_end = zoneData.meter_end;\n    const total_meter_length = meter_end - meter_start;\n    \n    if (total_meter_length <= 0) {\n        return { x: path_points[0].x, y: path_points[0].y }; // No length, return start\n    }\n\n    // 1. Calculate Total Pixel Length\n    let total_pixel_length = 0;\n    let cumulative_pixel_lengths = [0];\n    for (let i = 1; i < path_points.length; i++) {\n        total_pixel_length += getDistance(path_points[i - 1], path_points[i]);\n        cumulative_pixel_lengths.push(total_pixel_length);\n    }\n    \n    if (total_pixel_length === 0) {\n         return { x: path_points[0].x, y: path_points[0].y };\n    }\n\n    // 2. Find target pixel distance\n    const meter_ratio = (meterValue - meter_start) / total_meter_length;\n    const target_pixel_distance = meter_ratio * total_pixel_length;\n\n    // 3. Find the correct path segment\n    for (let i = 1; i < path_points.length; i++) {\n        const p_start = path_points[i - 1];\n        const p_end = path_points[i];\n        const segment_start_px = cumulative_pixel_lengths[i - 1];\n        const segment_end_px = cumulative_pixel_lengths[i];\n\n        if (target_pixel_distance >= segment_start_px && target_pixel_distance <= segment_end_px) {\n            // This is the segment!\n            const segment_length_px = segment_end_px - segment_start_px;\n            if (segment_length_px === 0) {\n                return { x: p_start.x, y: p_start.y };\n            }\n            \n            const segment_ratio = (target_pixel_distance - segment_start_px) / segment_length_px;\n            \n            // Interpolate coordinates\n            const x = p_start.x + (p_end.x - p_start.x) * segment_ratio;\n            const y = p_start.y + (p_end.y - p_start.y) * segment_ratio;\n            return { x: x, y: y };\n        }\n    }\n    \n    // Fallback: if meter value is outside range, clamp to start or end\n    if (meterValue <= meter_start) return { x: path_points[0].x, y: path_points[0].y };\n    return { x: path_points[path_points.length - 1].x, y: path_points[path_points.length - 1].y };\n}\n\n\n// --- Main Node Logic ---\n\n// Get the decoded alarm data\nconst alarm = msg.payload;\nconst zone_id = alarm.description; // e.g., \"Zone_1\"\n\n// Get the map data we saved earlier\nconst all_zone_paths = flow.get(\"all_zone_paths\");\n\nif (!all_zone_paths) {\n    node.warn(\"all_zone_paths not in flow context yet.\");\n    return null;\n}\n\n// Find the specific zone's data\nconst zoneData = all_zone_paths.find(z => z.zone_id === zone_id);\nif (!zoneData) {\n    node.warn(`No map data found for zone: ${zone_id}`);\n    return null;\n}\n\n// Check if this is an ALARM or a CLEAR\nif (alarm.alarm) {\n    // This is an ALARM\n    let alarm_meter;\n    if (alarm.locations && alarm.locations.length > 0) {\n        // Use the first location's meter value\n        alarm_meter = alarm.locations[0].distance_m;\n    } else {\n        // No location, just put the dot in the middle of the zone\n        alarm_meter = (zoneData.meter_start + zoneData.meter_end) / 2;\n    }\n\n    // Convert meter value to (x, y)\n    const coords = meterToCoords(alarm_meter, zoneData);\n\n    if (!coords) {\n        // This can happen if a zone has an alarm but no path drawn for it yet\n        // node.warn(`Could not calculate coordinates for ${zone_id} at ${alarm_meter}m`);\n        return null;\n    }\n    \n    msg.payload = {\n        type: \"ALARM_UPDATE\",\n        alarm: {\n            zone_id: zone_id,\n            coords: coords\n        }\n    };\n    return msg;\n\n} else {\n    // This is a CLEAR message\n    msg.payload = {\n        type: \"ALARM_CLEAR\",\n        zone_id: zone_id\n    };\n    return msg;\n}\n",
