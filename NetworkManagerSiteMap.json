    {
        "id": "0d53f125ecdce0fe",
        "type": "function",
        "z": "04a5753d1cd88563",
        "name": "Build All Paths Query",
        "func": "// This query selects all zones and aggregates their path segments\n// into a JSON array, ordered by meter position.\nmsg.query = `\n    SELECT \n        z.zone_id, \n        z.meter_start, \n        z.meter_end, \n        json_agg(\n            json_build_object(\n                'x', m.x_coord, \n                'y', m.y_coord,\n                'meter', m.meter_position\n            ) ORDER BY m.meter_position\n        ) AS path_points\n    FROM zones z\n    JOIN map_path_segments m ON z.zone_id = m.zone_id\n    GROUP BY z.zone_id, z.meter_start, z.meter_end;\n`;\nmsg.payload = null;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 120,
        "wires": [
            [
                "c0b94314d1319131"
            ]
        ]
    },
    {
        "id": "c0b94314d1319131",
        "type": "postgresql",
        "z": "04a5753d1cd88563",
        "name": "Get All Paths",
        "query": "",
        "postgreSQLConfig": "112969890e9876a0",
        "split": false,
        "rowsPerMsg": 1,
        "outputs": 1,
        "x": 630,
        "y": 120,
