    {
        "id": "e99e1f59f3f95471",
        "type": "function",
        "z": "04a5753d1cd88563",
        "name": "Format All Paths",
        "func": "// msg.payload is an array of all zones with their path_points\nconst zones = msg.payload;\n\n// We need to save this to a flow variable so our alarm\n// processor can use it later for interpolation.\nflow.set(\"all_zone_paths\", zones);\n\n// Send this to the operator map to draw everything\nmsg.payload = { type: \"LOAD_ALL_ZONES\", zones: zones };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 120,
        "wires": [
            [
                "493ca686ddd04872"
            ]
        ]
    },
    {
        "id": "493ca686ddd04872",
        "type": "ui-template",
        "z": "04a5753d1cd88563",
        "group": "0c32d823ab741d49",
        "page": "",
        "ui": "",
        "name": "Operator Map",
        "order": 1,
        "width": "7",
        "height": "12",
        "head": "",
        "format": "<template>\n    <div \n        style=\"width: 100%; height: 100%; border: 1px solid #333; overflow: hidden; position: relative;\"\n        @wheel.prevent=\"onWheel\"\n        @mousedown.prevent=\"onMouseDown\"\n        @mousemove.prevent=\"onMouseMove\"\n        @mouseup.prevent=\"onMouseUp\"\n        @mouseleave.prevent=\"onMouseLeave\"\n        :style=\"{ cursor: isPanning ? 'grabbing' : 'grab' }\"\n        ref=\"mapContainer\"\n    >\n        <div \n            style=\"position: relative; width: fit-content; height: fit-content; transform-origin: 0 0;\"\n            :style=\"panningContainerStyle\"\n        >\n            <img \n                :src=\"mapUrl\" \n                @load=\"onMapLoad\"\n                style=\"display: block; pointer-events: none;\"\n                ref=\"mapImage\"\n                draggable=\"false\"\n            >\n            \n            \n            <svg \n                :style=\"svgStyle\"\n                style=\"position: absolute; top: 0; left: 0; pointer-events: none;\"\n            >\n                \n                <path v-for=\"(zone, zoneId) in zones\" :key=\"zoneId\"\n                    :d=\"zone.svgPath\"\n                    :stroke=\"zone.color\"\n                    stroke-width=\"5\"\n                    fill=\"none\"\n                />\n\n                \n                <circle v-for=\"(zone, zoneId) in alarmZones\" :key=\"'dot-' + zoneId\"\n                    :cx=\"zone.alarm_coords.x\"\n                    :cy=\"zone.alarm_coords.y\"\n                    r=\"8\"\n                    fill=\"red\"\n                    stroke=\"white\"\n                    stroke-width=\"2\"\n                />\n\n                \n                <g \n                    style=\"font-size: 10px; font-weight: bold; text-anchor: middle; dominant-baseline: middle; pointer-events: none;\"\n                >\n                    <text v-for=\"(label, index) in labels\" :key=\"'label-' + index\"\n                        :x=\"label.x_coord\"\n                        :y=\"label.y_coord\"\n                        fill=\"white\"\n                        stroke=\"black\"\n                        stroke-width=\"0.5\"\n                        paint-order=\"stroke\"\n                    >\n                        {{ label.label_text }}\n                    </text>\n                </g>\n\n            </svg>\n        </div>\n    </div>\n</template>\n\n<script>\n    export default {\n        watch: {\n            msg(msg) {\n                if (!msg.payload) return;\n\n                if (msg.payload.type === \"LOAD_ALL_ZONES\") {\n                    // This is the initial data from the DB\n                    this.processZoneData(msg.payload.zones);\n                }\n                if (msg.payload.type === \"LOAD_ALL_LABELS\") {\n                    // This is the new label data from the DB\n                    this.labels = msg.payload.labels;\n                }\n                if (msg.payload.type === \"LOAD_DEFAULT_VIEW\") {\n                    // This is the new view data from the DB\n                    this.scale = msg.payload.view.scale;\n                    this.translateX = msg.payload.view.translateX;\n                    this.translateY = msg.payload.view.translateY;\n                }\n                if (msg.payload.type === \"ALARM_UPDATE\") {\n                    // This is a live alarm from the Senstar flow\n                    this.handleAlarm(msg.payload.alarm);\n                }\n                if (msg.payload.type === \"ALARM_CLEAR\") {\n                    // This is a clear message\n                    this.handleClear(msg.payload.zone_id);\n                }\n            }\n        },\n        data() {\n            return {\n                mapUrl: \"/map-image?_t=\" + Date.now(),\n                svgStyle: {\n                    width: '0px',\n                    height: '0px'\n                },\n                zones: {},\n                labels: [], // <-- ADDED to store labels\n                scale: 1,\n                translateX: 0,\n                translateY: 0,\n                isPanning: false,\n                panStartX: 0,\n                panStartY: 0\n            }\n        },\n        computed: {\n            alarmZones() {\n                return Object.values(this.zones).filter(z => z.inAlarm);\n            },\n            panningContainerStyle() {\n                return {\n                    transform: `scale(${this.scale}) translate(${this.translateX}px, ${this.translateY}px)`\n                };\n            }\n        },\n        methods: {\n            onMapLoad() {\n                const img = this.$refs.mapImage;\n                if (img) {\n                    this.svgStyle.width = img.naturalWidth + 'px';\n                    this.svgStyle.height = img.naturalHeight + 'px';\n                }\n            },\n            generateSvgPath(path_points) {\n                if (!path_points || path_points.length < 2 || path_points[0] === null) return \"\";\n                const firstPoint = path_points[0];\n                const otherPoints = path_points.slice(1).map(p => `L ${p.x} ${p.y}`).join(\" \");\n                return `M ${firstPoint.x} ${firstPoint.y} ${otherPoints}`;\n            },\n            processZoneData(zonesData) {\n                let newZones = {};\n                zonesData.forEach(zone => {\n                    // Check for valid path_points array before generating SVG\n                    if (zone.path_points && zone.path_points.length > 0 && zone.path_points[0] && zone.path_points[0].x !== null) {\n                         newZones[zone.zone_id] = {\n                            ...zone,\n                            svgPath: this.generateSvgPath(zone.path_points),\n                            inAlarm: false,\n                            color: 'lime',\n                            alarm_coords: null\n                        }\n                    }\n                });\n                this.zones = newZones;\n            },\n            handleAlarm(alarm) {\n                const zone = this.zones[alarm.zone_id];\n                if (zone) {\n                    zone.inAlarm = true;\n                    zone.color = 'red';\n                    zone.alarm_coords = alarm.coords;\n                }\n            },\n            handleClear(zone_id) {\n                const zone = this.zones[zone_id];\n                if (zone) {\n                    zone.inAlarm = false;\n                    zone.color = 'lime';\n                    zone.alarm_coords = null;\n                }\n            },\n            onMouseDown(event) {\n                this.isPanning = true;\n                this.panStartX = event.clientX;\n                this.panStartY = event.clientY;\n            },\n            onMouseUp(event) {\n                this.isPanning = false;\n            },\n            onMouseLeave(event) {\n                this.isPanning = false;\n            },\n            onMouseMove(event) {\n                if (!this.isPanning) return;\n                const dx = (event.clientX - this.panStartX) / this.scale;\n                const dy = (event.clientY - this.panStartY) / this.scale;\n                this.translateX += dx;\n                this.translateY += dy;\n                this.panStartX = event.clientX;\n                this.panStartY = event.clientY;\n            },\n            onWheel(event) {\n                const minScale = 0.2;\n                const maxScale = 10;\n                const zoomIntensity = 0.1;\n\n                const delta = event.deltaY > 0 ? -1 : 1;\n                const zoomFactor = 1 + delta * zoomIntensity;\n\n                const oldScale = this.scale;\n                let newScale = oldScale * zoomFactor;\n\n                // Clamp scale\n                if (newScale < minScale) newScale = minScale;\n                if (newScale > maxScale) newScale = maxScale;\n                \n                if (newScale === oldScale) return;\n\n                const rect = this.$refs.mapContainer.getBoundingClientRect();\n                const mouseX = event.clientX - rect.left;\n                const mouseY = event.clientY - rect.top;\n\n                // Position of mouse on the un-scaled content\n                const mouseOnContentX = (mouseX / oldScale) - this.translateX;\n                const mouseOnContentY = (mouseY / oldScale) - this.translateY;\n                \n                // Calculate new translation to keep mouseOnContent at the same screen position\n                this.translateX = (mouseX / newScale) - mouseOnContentX;\n                this.translateY = (mouseY / newScale) - mouseOnContentY;\n                this.scale = newScale;\n            }\n        }\n    }\n</script>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1080,
        "y": 160,
        "wires": [
