        "type": "function",
        "z": "04a5753d1cd88563",
        "name": "Format HTTP Response",
        "func": "// msg.payload will be an array with one result\nif (!msg.payload || msg.payload.length === 0 || !msg.payload[0].image_data) {\n    msg.statusCode = 404;\n    msg.payload = \"Map image not found in database.\";\n    return msg;\n}\n\nconst db_row = msg.payload[0];\n\n// Set the content type header to tell the browser this is an image\nmsg.headers = {\n    \"Content-Type\": db_row.mime_type\n};\n\n// Set the payload to be the raw image buffer\nmsg.payload = db_row.image_data;\n\nreturn msg;",
